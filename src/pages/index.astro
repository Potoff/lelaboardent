---
import Base from '../layouts/Base.astro';
---
<Base>
  <div class="top">
    <div class="brand">Labo Ardent</div>
    <nav>
      <a href="#feu">Feu</a>
      <a href="#ferment">Ferment</a>
      <a href="#registre">Le registre</a>
      <a href="#trouver">Où me trouver</a>
    </nav>
    <div class="mono" style="font-size:11px">Sud Ardèche · 2026</div>
  </div>

  <!-- HERO photo -->
  <header class="hero2">
    <div class="txt">
      <p class="ey">· Feu &amp; ferment ·</p>
      <h1>Fumé.<br><em>Fermenté.</em><br><span class="out">Vivant.</span></h1>
      <p class="lede">Un petit labo en Ardèche. Je fais du <b>piment fumé au bois de châtaignier</b> et des <b>boissons vivantes</b>. Que des petits lots, faits à la main.</p>
      <a class="cta" href="#registre">Voir le registre →</a>
    </div>
    <div class="img" style="background-image:url('/img/hero.jpg')">
      <div class="stamp2 ink" aria-hidden="true">
        <svg viewBox="0 0 620 250">
          <g fill="none" stroke="#EAE0CD"><rect x="16" y="16" width="588" height="218" stroke-width="6"/><rect x="28" y="28" width="564" height="194" stroke-width="2"/></g>
          <g fill="#EAE0CD">
            <text x="310" y="62" text-anchor="middle" font-family="Space Mono" font-weight="700" font-size="14" letter-spacing="6">· FEU &amp; FERMENT ·</text>
            <text x="310" y="140" text-anchor="middle" font-family="Anton" font-size="76" letter-spacing="2">LABO ARDENT</text>
            <text x="310" y="176" text-anchor="middle" font-family="Jost" font-weight="700" font-size="15" letter-spacing="3">PIMENTS FUMÉS &amp; BOISSONS VIVANTES</text>
            <path d="M64 150 c 9 11 -2 17 3 26 c 7 -5 6 -16 2 -24 c 10 7 12 20 3 30 c -9 8 -22 2 -20 -11 c 1 -8 9 -10 12 -21 z"/>
            <path d="M556 150 c 9 11 -2 17 3 26 c 7 -5 6 -16 2 -24 c 10 7 12 20 3 30 c -9 8 -22 2 -20 -11 c 1 -8 9 -10 12 -21 z"/>
            <text x="310" y="206" text-anchor="middle" font-family="Space Mono" font-weight="400" font-size="12" letter-spacing="3">LOT _____ · FAIT MAIN · SUD ARDÈCHE · 2026</text>
          </g>
        </svg>
      </div>
    </div>
  </header>

  <!-- MARQUEE -->
  <div class="marq" aria-hidden="true">
    <div class="track">
      <span>Piment fumé au châtaignier <span class="dot">·</span> Ginger beer vivante <span class="dot">·</span> Petits lots <span class="dot">·</span> Fait main <span class="dot">·</span> Sud Ardèche <span class="dot">·</span> </span>
      <span>Piment fumé au châtaignier <span class="dot">·</span> Ginger beer vivante <span class="dot">·</span> Petits lots <span class="dot">·</span> Fait main <span class="dot">·</span> Sud Ardèche <span class="dot">·</span> </span>
    </div>
  </div>

  <!-- TUILES FEU / FERMENT -->
  <section class="tiles">
    <article class="tile feu" id="feu">
      <div class="bg" style="background-image:url('/img/feu.jpg')"></div>
      <div class="c">
        <div class="k">Le feu</div>
        <h2>Piments<br>fumés</h2>
        <p>Séchés puis fumés au bois de châtaignier d'ici. Poudres, flocons, entiers. Du doux qui parfume au brutal qui réveille.</p>
      </div>
    </article>
    <article class="tile fer" id="ferment">
      <div class="bg" style="background-image:url('/img/ferment.jpg')"></div>
      <div class="c">
        <div class="k">Le ferment</div>
        <h2>Boissons<br>vivantes</h2>
        <p>Ginger beer non pasteurisée, lancée au ginger bug maison. Ça fermente lentement, ça pétille tout seul, c'est vivant.</p>
      </div>
    </article>
  </section>

  <!-- REGISTRE -->
  <section class="reg" id="registre">
    <div class="inner">
      <div class="h">
        <h2>Le registre</h2>
        <p class="sub">Chaque lot est daté, testé, noté. Rien ne sort du labo sans passer par le cahier.</p>
      </div>
      <div class="cards">
        <article class="fiche">
          <span class="tag">Feu</span>
          <div class="lot"><span>Piment</span><b>LOT 07·A</b></div>
          <h3>Fumé<br>châtaignier</h3>
          <p>Ma signature. Séché puis fumé six heures au bois de châtaignier.</p>
          <div class="data"><div class="r"><span>Force</span><b>~15 000 SHU</b></div><div class="r"><span>Fumage</span><b>6 h</b></div></div>
        </article>
        <article class="fiche fmt">
          <span class="tag">Ferment</span>
          <div class="lot"><span>Boisson</span><b>LOT G·03</b></div>
          <h3>Ginger beer<br>sauvage</h3>
          <p>Gingembre frais, ferment lent au ginger bug, non pasteurisée.</p>
          <div class="data"><div class="r"><span>Ferment</span><b>5 jours</b></div><div class="r"><span>Sucre</span><b>Bas</b></div></div>
        </article>
        <article class="fiche">
          <span class="tag">Feu</span>
          <div class="lot"><span>Condiment</span><b>LOT S·02</b></div>
          <h3>Sel fumé<br>maison</h3>
          <p>Sel fumé au châtaignier, pour finir un plat avec une pointe de braise.</p>
          <div class="data"><div class="r"><span>Fumage</span><b>4 h</b></div><div class="r"><span>Grain</span><b>Gros</b></div></div>
        </article>
        <article class="fiche essai">
          <div class="lot"><span>Essai</span><b>LOT ??</b></div>
          <h3>Sauce<br>lacto-fermentée</h3>
          <p>Piment fumé en sauce lacto. Encore au labo. Je vous dis quand c'est prêt.</p>
          <div class="data"><div class="r"><span>Statut</span><b>En essai</b></div><div class="r"><span>Sortie</span><b>2027</b></div></div>
        </article>
      </div>
    </div>
  </section>

  <!-- STORY photo -->
  <section class="story2">
    <div class="img" style="background-image:url('/img/story.jpg')"></div>
    <div class="txt">
      <p class="ey">· Le labo ·</p>
      <h2>Tout se fait<br>à la main.</h2>
      <p>Pas d'usine, pas de recette figée. Je fume, je sèche, je fais fermenter, je goûte, je note. <b>Un lot après l'autre, jusqu'à ce que ce soit bon.</b> C'est plus long, c'est vivant, et ça se sent.</p>
    </div>
  </section>

  <!-- TROUVER photo -->
  <section class="trouver" id="trouver">
    <div class="bg" style="background-image:url('/img/market.jpg')"></div>
    <div class="c">
      <p class="ey">· Où me trouver ·</p>
      <p>Pas en supermarché. Sur les <em>marchés du sud Ardèche</em>, en direct, et bientôt en ligne.</p>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <div class="inner">
      <div class="fstamp ink" aria-hidden="true">
        <svg viewBox="0 0 300 300">
          <g fill="none" stroke="#E7DCC6"><circle cx="150" cy="150" r="140" stroke-width="2.5"/><circle cx="150" cy="150" r="132" stroke-width="6"/><circle cx="150" cy="150" r="90" stroke-width="2"/></g>
          <g fill="#E7DCC6">
            <path d="M150 96 c 16 20 -3 30 5 46 c 13 -8 10 -28 3 -42 c 18 12 22 36 5 52 c -16 15 -40 4 -37 -20 c 2 -14 16 -18 21 -36 z" transform="translate(0,6)"/>
            <text x="150" y="196" text-anchor="middle" font-family="Space Mono" font-weight="700" font-size="12" letter-spacing="2">EST. 2026</text>
            <defs><path id="ft" d="M 44,150 A 106,106 0 0 1 256,150"/><path id="fb" d="M 52,150 A 98,98 0 0 0 248,150"/></defs>
            <text><textPath href="#ft" startOffset="50%" text-anchor="middle" font-family="Anton" font-size="27" letter-spacing="2">LABO ARDENT</textPath></text>
            <text><textPath href="#fb" startOffset="50%" text-anchor="middle" font-family="Jost" font-weight="700" font-size="15" letter-spacing="3">FEU &amp; FERMENT</textPath></text>
          </g>
        </svg>
      </div>
      <div class="fcol"><b>Le labo</b><a href="#feu">Feu &amp; ferment</a><a href="#registre">Le registre</a><a href="#trouver">L'histoire</a></div>
      <div class="fcol"><b>Trouver</b><a href="#trouver">Les marchés</a><a href="mailto:bonjour@laboardent.com">M'écrire</a></div>
      <div class="fcol"><b>Infos</b><a href="/mentions-legales">Mentions légales</a><a href="#">Instagram</a><a href="#">TikTok</a></div>
    </div>
  </footer>
</Base>
